# ══════════════════════════════════════════════════════
# ClinicFlow — .env PRODUÇÃO
# Copiar para infra/.env.production e preencher
# NUNCA commitar este arquivo no Git!
# ══════════════════════════════════════════════════════

# Domínio principal (sem https://)
DOMAIN=clinicflow.com.br

# Email para certificado Let's Encrypt
ACME_EMAIL=pedro@rothadigital.online

# Traefik dashboard — gere com: htpasswd -nb admin SENHA
# Instalar: apt install apache2-utils
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$xxxxxxxxxxxxxxxxxxxxxx

# ── MySQL ──────────────────────────────────────────────
DATABASE_URL=mysql://clinicflow_user:SENHA@192.168.10.141:3306/clinicflow

# ── Redis ──────────────────────────────────────────────
REDIS_PASSWORD=SENHA_REDIS_FORTE
REDIS_URL=redis://:SENHA_REDIS_FORTE@redis:6379

# ── JWT ────────────────────────────────────────────────
# Gere: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERAR_SECRET_64_CHARS
JWT_REFRESH_SECRET=GERAR_REFRESH_SECRET_64_CHARS

# ── Evolution API ──────────────────────────────────────
EVOLUTION_URL=http://192.168.10.140:8080
EVOLUTION_API_KEY=SUA_CHAVE_EVOLUTION

# ── N8N ────────────────────────────────────────────────
N8N_URL=http://192.168.10.141:5678
N8N_WEBHOOK_URL=http://192.168.10.141:5678

# ── MinIO ──────────────────────────────────────────────
MINIO_USER=clinicflow_minio
MINIO_PASSWORD=SENHA_MINIO_FORTE
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=clinicflow_minio
MINIO_SECRET_KEY=SENHA_MINIO_FORTE
MINIO_BUCKET=clinicflow-exams

# ── App ────────────────────────────────────────────────
PORT=3333
NODE_ENV=production
FRONTEND_URL=https://app.clinicflow.com.br
