# CLINICFLOW INFRA — .env
# ══════════════════════════════════════════

# MySQL externo (não está no Docker)
MYSQL_HOST=192.168.10.141
MYSQL_PORT=3306
MYSQL_USER=clinicflow_user
MYSQL_PASSWORD=sua_senha_mysql_forte

# Redis
REDIS_PASSWORD=sua_senha_redis_forte

# Evolution API
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_DB_URI=mysql://clinicflow_user:sua_senha@192.168.10.141:3306/evolution

# n8n
N8N_USER=admin
N8N_PASSWORD=sua_senha_n8n
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br
N8N_ENCRYPTION_KEY=gere-uma-chave-32-chars-aqui

# MinIO
MINIO_USER=clinicflow_minio
MINIO_PASSWORD=sua_senha_minio_forte

# URLs públicas
API_URL=https://api.clinicflow.com.br
SOCKET_URL=https://api.clinicflow.com.br
FRONTEND_URL=https://app.clinicflow.com.br
